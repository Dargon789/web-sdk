{
  "name": "@0xsequence/checkout",
  "version": "6.0.2",
  "description": "Checkout UI for Sequence Web SDK",
  "repository": "https://github.com/0xsequence/web-sdk/tree/master/packages/checkout",
  "author": "Sequence Platforms ULC",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/esm/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "default": "./dist/esm/index.js"
    }
  },
  "files": [
    "dist",
    "src/**/*.ts",
    "src/**/*.tsx",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/*.test-d.ts"
  ],
  "scripts": {
    "build": "pnpm build:clean && pnpm build:esm",
    "build:esm": "tsc --verbatimModuleSyntax false --declaration --declarationMap --outDir dist/esm",
    "build:clean": "rimraf -g ./dist",
    "build:check": "attw --pack .",
    "dev": "tsc --watch --verbatimModuleSyntax false --declaration --declarationMap --outDir dist/esm",
    "test": "echo",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@0xsequence/design-system": "2.1.11",
    "@0xsequence/marketplace": "^2.3.38",
    "date-fns": "^4.1.0",
    "fuse.js": "^7.1.0",
    "motion": "^12.9.2",
    "qrcode.react": "^4.2.0"
  },
  "peerDependencies": {
    "@0xsequence/connect": "workspace:*",
    "@0xsequence/hooks": "workspace:*",
    "@0xsequence/indexer": ">= 3.0.1",
    "@0xsequence/metadata": ">= 3.0.1",
    "@tanstack/react-query": ">= 5",
    "react": ">= 17",
    "react-dom": ">= 17",
    "viem": ">= 2.45.0",
    "wagmi": ">= 3.2.0"
  },
  "devDependencies": {
    "@0xsequence/connect": "workspace:*",
    "@tanstack/react-query": "^5.74.11",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "viem": "^2.45.1",
    "wagmi": "^3.2.0"
  }
}
