{
  "name": "@0xsequence/connect",
  "version": "6.0.2",
  "description": "Connect package for Sequence Web SDK",
  "keywords": [
    "sequence",
    "web-sdk",
    "wallet"
  ],
  "repository": "https://github.com/0xsequence/web-sdk/tree/master/packages/connect",
  "author": "Sequence Platforms ULC",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/esm/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "default": "./dist/esm/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm run writeVersion && pnpm build:clean && pnpm build:css && pnpm build:esm",
    "build:esm": "tsc --verbatimModuleSyntax false --declaration --declarationMap --outDir dist/esm",
    "build:css": "node scripts/build-css.js && prettier --write src/styles.ts",
    "build:clean": "rimraf -g ./dist",
    "build:check": "attw --pack .",
    "dev": "pnpm run writeVersion && concurrently \"pnpm dev:tsc\"  \"pnpm watch-css\"",
    "dev:tsc": "tsc --watch --verbatimModuleSyntax false --declaration --declarationMap --outDir dist/esm",
    "watch-css": "node scripts/watch-css.js",
    "writeVersion": "node scripts/writeVersion.js",
    "test": "echo",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@0xsequence/dapp-client": ">=3.0.1",
    "@0xsequence/api": ">=3.0.1",
    "@0xsequence/auth": "^2.3.38",
    "@0xsequence/core": "^2.3.38",
    "@0xsequence/design-system": "3.2.9",
    "@0xsequence/ethauth": "^1.0.0",
    "@0xsequence/indexer": ">=3.0.1",
    "@0xsequence/wallet-primitives": ">=3.0.1",
    "@0xsequence/provider": "^2.3.38",
    "@0xsequence/waas": "^2.3.38",
    "clsx": "^2.1.1",
    "fuse.js": "^7.1.0",
    "motion": "^12.9.2",
    "uuid": "^10.0.0"
  },
  "peerDependencies": {
    "0xsequence": ">= 2.3.38",
    "@0xsequence/hooks": "workspace:*",
    "@coinbase/wallet-sdk": "^4.3.6",
    "@databeat/tracker": "^0.9.3",
    "@metamask/sdk": "~0.33.1",
    "@react-oauth/google": "^0.11.1",
    "@tanstack/react-query": ">= 5",
    "@walletconnect/ethereum-provider": "^2.21.1",
    "react": ">= 17",
    "react-apple-signin-auth": "^1.1.0",
    "react-dom": ">= 17",
    "viem": ">= 2.45.0",
    "wagmi": ">= 3.2.0"
  },
  "peerDependenciesMeta": {
    "@coinbase/wallet-sdk": {
      "optional": true
    },
    "@metamask/sdk": {
      "optional": true
    },
    "@walletconnect/ethereum-provider": {
      "optional": true
    }
  },
  "devDependencies": {
    "0xsequence": "^2.3.38",
    "@0xsequence/hooks": "workspace:*",
    "@databeat/tracker": "^0.9.3",
    "@react-oauth/google": "^0.11.1",
    "@tanstack/react-query": "^5.74.11",
    "@types/uuid": "^9.0.8",
    "@tailwindcss/cli": "^4.1.11",
    "concurrently": "^9.1.2",
    "react": "^19.1.0",
    "react-apple-signin-auth": "^1.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.1.11",
    "viem": "^2.45.1",
    "wagmi": "^3.2.0"
  }
}
