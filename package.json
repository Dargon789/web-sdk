{
  "name": "web-sdk",
  "private": true,
  "license": "Apache-2.0",
  "sideEffects": false,
  "scripts": {
    "build": "turbo run build --filter={packages/*}",
    "build:clean": "turbo run build:clean",
    "dev": "turbo run dev --filter={packages/*}",
    "reinstall": "rimraf -g ./**/node_modules && pnpm install",
    "test": "turbo run test",
    "lint": "eslint -c eslint.config.mjs '{packages,examples}/**/src/**/*.{ts,tsx}'",
    "lint:fix": "eslint -c eslint.config.mjs --fix '{packages,examples}/**/src/**/*.{ts,tsx}'",
    "prettier:check": "prettier --list-different './{packages,examples}/*/src/**/*.{ts,tsx}'",
    "prettier:fix": "prettier --list-different --write './{packages,examples}/*/src/**/*.{ts,tsx}'",
    "format": "pnpm run lint:fix && pnpm run prettier:fix",
    "audit:fix": "pnpm audit --fix",
    "typecheck": "tsc --noEmit",
    "deps": "pnpx taze -r",
    "deps:lint": "syncpack lint --dependency-types prod,dev",
    "deps:fix": "syncpack fix",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm build && changeset publish",
    "dev:react": "pnpm --filter example-react dev",
    "dev:aave": "pnpm --filter example-aave dev",
    "debug:react": "DEBUG=true pnpm dev:react",
    "serve:react": "pnpm --filter example-react serve",
    "build:react": "pnpm --filter example-react build",
    "dev:react-boilerplate": "pnpm --filter example-react-boilerplate dev",
    "serve:react-boilerplate": "pnpm --filter example-react-boilerplate serve",
    "build:react-boilerplate": "pnpm --filter example-react-boilerplate build",
    "dev:next": "pnpm --filter example-next dev",
    "serve:next": "pnpm --filter example-next start",
    "build:next": "pnpm --filter example-next build",
    "dev:react-waas": "pnpm --filter example-react-waas dev",
    "debug:react-waas": "DEBUG=true pnpm dev:react-waas",
    "serve:react-waas": "pnpm --filter example-react-waas serve",
    "build:react-waas": "pnpm --filter example-react-waas build",
    "prepare": "husky",
    "knip": "knip"
  },
  "devDependencies": {
    "@0xsequence/connect": "workspace:*",
    "@arethetypeswrong/cli": "^0.17.4",
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.19.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.7",
    "knip": "^5.88.1",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^5.0.10",
    "syncpack": "^14.2.0",
    "turbo": "2.8.19",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "viem": "^2.47.5",
    "wagmi": "3.2.0"
  },
  "resolutions": {},
  "packageManager": "pnpm@9.15.9+sha512.68046141893c66fad01c079231128e9afb89ef87e2691d69e4d40eee228988295fd4682181bae55b58418c3a253bde65a505ec7c5f9403ece5cc3cd37dcf2531",
  "dependencies": {
    "flag": "^5.0.1",
    "kit-connectors#build": "link:@0xsequence/kit-connectors#build",
    "vercel": "link:../../../../../home/legion/.local/share/pnpm/global/5/node_modules/vercel"
  }
}
